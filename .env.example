# ─────────────────────────────────────────────────────────────────────────────
# SpaceHarbor Environment Variables
# Copy to .env and fill in values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────
#
# PRODUCTION REQUIRED: SPACEHARBOR_JWT_SECRET
#   When IAM is enabled (SPACEHARBOR_IAM_ENABLED=true), the control-plane will
#   refuse to start in production unless this is set to a strong random value.
#   If unset, JWT token issuance falls back to a hardcoded insecure secret,
#   allowing any party who knows the default to forge tokens.
#   Generate: openssl rand -base64 32
#
# PRODUCTION REQUIRED: SPACEHARBOR_ADMIN_EMAIL / SPACEHARBOR_ADMIN_PASSWORD
#   Required to bootstrap the initial super_admin account. After first login,
#   rotate the password and remove SPACEHARBOR_ADMIN_PASSWORD from env.
#
# PRODUCTION REQUIRED (at least one auth mechanism):
#   SPACEHARBOR_IAM_ENABLED=true          — full RBAC + JWT auth
#   SPACEHARBOR_API_KEY / _API_KEYS       — API key auth for service accounts
#   SPACEHARBOR_OIDC_JWKS_URI             — external OIDC IdP token verification
#   Without any of these, the server will refuse to start in NODE_ENV=production.
#
SPACEHARBOR_JWT_SECRET=dev-jwt-secret-change-in-production
SPACEHARBOR_ADMIN_EMAIL=admin@spaceharbor.dev
SPACEHARBOR_ADMIN_PASSWORD=Admin1234!dev

# ── Control Plane ────────────────────────────────────────────────────────────

# Persistence backend: "local" (in-memory/file) or "vast" (Trino + VAST DB)
SPACEHARBOR_PERSISTENCE_BACKEND=local

# When backend=vast, reject operations if Trino is unreachable
SPACEHARBOR_VAST_STRICT=false

# When backend=vast, fall back to local adapter if Trino is unavailable
SPACEHARBOR_VAST_FALLBACK_TO_LOCAL=true

# API key for authenticating control-plane requests (empty = auth disabled)
# BACKWARD COMPAT: A single shared key still works for all services.
SPACEHARBOR_API_KEY=

# ── Per-Service Credentials (recommended for production) ─────────────────
# Each service gets its own unique API key. The control-plane accepts ALL of
# them (it is the API gateway). Each downstream service only needs its own
# key to authenticate with the control-plane. Compromising one service key
# does not grant access as another service.
#
# Generate unique keys, e.g.: openssl rand -base64 32
SPACEHARBOR_API_KEY_CONTROL_PLANE=
SPACEHARBOR_API_KEY_MEDIA_WORKER=
SPACEHARBOR_API_KEY_SCANNER=
SPACEHARBOR_API_KEY_OPENASSETIO=

# Control-plane URL used by external services (scanner-function, openassetio-manager)
SPACEHARBOR_CONTROL_PLANE_URL=http://localhost:8080

# HTTP server bind settings
PORT=8080
HOST=0.0.0.0

# ── Replay / Job Re-processing ──────────────────────────────────────────────

# Enable/disable job replay endpoint (default: true)
SPACEHARBOR_REPLAY_ENABLED=true

# Max replays per minute rate limit (default: 60)
SPACEHARBOR_REPLAY_MAX_PER_MINUTE=60

# ── Webhook Notifications ───────────────────────────────────────────────────

# Outbound webhook URLs (leave empty to skip that target)
SPACEHARBOR_WEBHOOK_SLACK_URL=
SPACEHARBOR_WEBHOOK_TEAMS_URL=
SPACEHARBOR_WEBHOOK_PRODUCTION_URL=

# HMAC signing secret for webhook payloads (required when strict mode is on)
SPACEHARBOR_WEBHOOK_SIGNING_SECRET=

# Require all configured webhook targets + signing secret (default: false)
SPACEHARBOR_WEBHOOK_STRICT_MODE=false

# ── Audit Log Retention ─────────────────────────────────────────────────────

# Enable automatic audit log retention (default: true)
SPACEHARBOR_AUDIT_RETENTION_ENABLED=true

# Retention mode: "dry-run" (log only) or "apply" (delete old records)
SPACEHARBOR_AUDIT_RETENTION_MODE=dry-run

# Number of days to retain audit logs (default: 90)
SPACEHARBOR_AUDIT_RETENTION_DAYS=90

# Interval in seconds between retention sweeps (default: 86400 = 24h)
SPACEHARBOR_AUDIT_RETENTION_INTERVAL_SECONDS=86400

# Max records to delete per sweep (empty = unlimited)
SPACEHARBOR_AUDIT_RETENTION_MAX_DELETE_PER_RUN=

# ── Lease Reaping ─────────────────────────────────────────────────────────

# Enable background reaping of expired worker leases (default: true)
SPACEHARBOR_LEASE_REAPING_ENABLED=true

# Interval in seconds between lease-reaping sweeps (default: 30)
SPACEHARBOR_LEASE_REAPING_INTERVAL_SECONDS=30

# ── Job Retries / DLQ ────────────────────────────────────────────────────

# Max retry attempts before moving a failed job to the DLQ (default: 3)
SPACEHARBOR_MAX_JOB_ATTEMPTS=3

# ── VAST Data Platform ──────────────────────────────────────────────────────

# VAST Database URL (leave empty for local-only mode)
VAST_DATABASE_URL=

# VAST DataEngine URL (used for oiio-proxy, exr-inspector functions)
VAST_DATAENGINE_URL=
# Legacy alias (deprecated): VAST_DATA_ENGINE_URL

# VAST API credentials
VAST_API_TOKEN=
VAST_API_KEY=
VAST_ACCESS_KEY=
VAST_SECRET_KEY=

# ── VAST Database (SQL Interface) ──────────────────────────────────────────
# VAST Database exposes a Trino-compatible SQL endpoint.
# Find the endpoint in VMS > Data Services or ask your VAST admin.

# VAST Database SQL endpoint (e.g., https://<VAST_VIP>:8443)
VAST_DB_ENDPOINT=
# Deprecated alias (still supported): VAST_TRINO_ENDPOINT

# VAST Database credentials (S3 access key pair)
VAST_DB_USERNAME=
VAST_DB_PASSWORD=
# Deprecated aliases (still supported): VAST_TRINO_USERNAME, VAST_TRINO_PASSWORD

# ── VAST Event Broker (Kafka) ──────────────────────────────────────────────

# Kafka broker URL for VAST event subscription (leave empty to disable)
VAST_EVENT_BROKER_URL=

# Kafka topic for DataEngine completion events
VAST_EVENT_BROKER_TOPIC=spaceharbor.dataengine.completed

# Kafka consumer group ID
VAST_EVENT_BROKER_GROUP=spaceharbor-control-plane

# Enable SSL for Kafka connection (MUST be true in production)
VAST_EVENT_BROKER_SSL=true

# SASL authentication for VAST Event Broker (Kafka).
# VAST Event Broker does NOT support AD/LDAP — use VAST local user credentials.
# Create a dedicated user: vastcmd user create --name spaceharbor-kafka
VAST_EVENT_BROKER_SASL_USERNAME=
VAST_EVENT_BROKER_SASL_PASSWORD=
# SASL mechanism. IMPORTANT: never use PLAIN without SSL enabled.
VAST_EVENT_BROKER_SASL_MECHANISM=PLAIN

# ── Media Worker (Python) ───────────────────────────────────────────────────

# Control-plane URL the worker polls for jobs
CONTROL_PLANE_URL=http://localhost:8080

# API key for worker -> control-plane auth
# In per-service mode, set to the same value as SPACEHARBOR_API_KEY_MEDIA_WORKER
CONTROL_PLANE_API_KEY=

# Worker identity and polling settings
WORKER_ID=media-worker-1
WORKER_POLL_SECONDS=2
WORKER_LEASE_SECONDS=30

# ── Web UI ──────────────────────────────────────────────────────────────────

# REMOVED: VITE_API_KEY — API keys with VITE_ prefix are embedded in client-side
# JS bundles and visible to end users. Use server-side proxy or OAuth instead.

# ── OpenAssetIO Manager ─────────────────────────────────────────────────────

# URL for the OpenAssetIO manager service
OPENASSETIO_MANAGER_URL=http://openassetio-manager:8001

# ── DataEngine Functions (Python) ───────────────────────────────────────────

# Kafka broker for DataEngine function output events
KAFKA_BROKER=vastbroker:9092

# Enable dev mode (skip VAST I/O, use local test files)
DEV_MODE=false

# OCIO config file path (oiio-proxy-generator; default: ACES 1.3 system path)
OCIO_CONFIG_PATH=

# Transcode profile name (ffmpeg-transcoder; see docs/ffmpeg-transcoder.md)
TRANSCODE_PROFILE=h264_review

# Output path for transcoded files (ffmpeg-transcoder)
VAST_OUTPUT_PATH=

# Optional: 3D LUT file for baked color transforms (ffmpeg-transcoder)
LUT_PATH=

# Optional: Separate audio file for dual-system mux (ffmpeg-transcoder)
AUDIO_SOURCE_PATH=

# Optional: Starting timecode HH:MM:SS:FF (ffmpeg-transcoder)
TIMECODE_START=

# Optional: Burn-in text overlay (ffmpeg-transcoder)
BURN_IN_TEXT=

# ── Integration Testing ─────────────────────────────────────────────────────

# Set to "true" to enable VAST Database integration tests
VAST_DB_INTEGRATION=false
# Legacy alias (deprecated): TRINO_INTEGRATION
