{
  "name": "assetharbor",
  "version": "0.1.0",
  "private": true,
  "description": "AssetHarbor MVP monorepo",
  "scripts": {
    "test:compose": "node --test tests/compose/*.test.js",
    "test:docs": "node --test tests/docs/docs-presence.test.js",
    "test:control-plane": "npm --prefix services/control-plane test",
    "test:contracts": "npm --prefix services/control-plane run test:contracts",
    "test:worker": "PYTHONPATH=services/media-worker python3 -m pytest services/media-worker/tests -q",
    "test:web-ui": "npm --prefix services/web-ui test",
    "test:all": "npm run test:compose && npm run test:docs && npm run test:contracts && npm run test:control-plane && npm run test:worker && npm run test:web-ui"
  }
}
