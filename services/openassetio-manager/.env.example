# OpenAssetIO Manager — Environment Variables
#
# DEV_MODE: Set to "true" only for local development without a control-plane.
# In production, this must be "false" (the default) and
# SPACEHARBOR_CONTROL_PLANE_URL must be set.
DEV_MODE=false

# Control-plane URL (required when DEV_MODE=false)
SPACEHARBOR_CONTROL_PLANE_URL=http://control-plane:8080

# VAST Database connection (used in non-dev mode for direct VAST Database queries)
# Deprecated aliases TRINO_HOST/TRINO_PORT are still supported as fallback.
VAST_DB_HOST=localhost
VAST_DB_PORT=8080

# API key for authenticating requests (H16 security hardening).
# When set, all endpoints except /health require a valid x-api-key header.
# When not set, auth is skipped (development mode only).
SPACEHARBOR_API_KEY=
