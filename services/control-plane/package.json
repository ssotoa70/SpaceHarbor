{
  "name": "@spaceharbor/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "test:contracts": "node --import tsx --test test/*contract*.test.ts test/*v1-contract*.test.ts",
    "db:install": "echo 'DEPRECATED: Use vast-migrate.py instead' && tsx src/db/installer.ts",
    "db:deploy": "python3 src/db/vast-migrate.py",
    "db:status": "python3 src/db/vast-migrate.py --status",
    "test:integration": "docker compose -f docker-compose.test.yml up -d --wait && TRINO_INTEGRATION=true node --import tsx --test test/integration/*.test.ts; docker compose -f docker-compose.test.yml down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/s3-request-presigner": "^3.1008.0",
    "@confluentinc/kafka-javascript": "^1.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "fastify": "^5.2.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
